{
  "buildCommand": "chmod +x ./node_modules/.bin/next && ./node_modules/.bin/next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/tenant-application/route.ts": {
      "maxDuration": 60
    },
    "app/api/guarantor/route.ts": {
      "maxDuration": 60
    },
    "app/api/landlord-registration/route.ts": {
      "maxDuration": 60
    },
    "app/api/maintenance/route.ts": {
      "maxDuration": 60
    },
    "app/api/rent-review/route.ts": {
      "maxDuration": 60
    },
    "app/api/staff/ledger-sync/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/ledger-sync/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/purge-deleted",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/compliance-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/ledger-sync",
      "schedule": "0 5 * * *"
    }
  ]
}